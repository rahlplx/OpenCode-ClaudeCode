# OpenCode-ClaudeCode environment reference
# All config is passed via CLI flags — no env vars are required.
# Copy this file to .env if you want to document your setup.

# ──────────────────────────────────────────────
# Server (CLI flags for: node dist-cli/index.js serve)
# ──────────────────────────────────────────────

# Port to listen on (default: 4080)
# --port 4080

# Host to bind (default: 0.0.0.0)
# --host 0.0.0.0

# Auth password. If omitted, --no-password disables auth entirely.
# --password your-secret-password

# Path to the opencode binary if not in PATH
# --opencode-path /usr/local/bin/opencode

# Directory to serve the pre-built frontend from
# --static-dir ./dist

# ──────────────────────────────────────────────
# Provider API keys (set in the UI Settings panel or via BYOK config)
# ──────────────────────────────────────────────

# OpenRouter API key (for BYOK / custom provider)
# OPENROUTER_API_KEY=sk-or-...

# Custom provider base URL (OpenAI-compatible endpoint)
# CUSTOM_BASE_URL=https://my-llm.example.com/v1

# Custom provider API key
# CUSTOM_API_KEY=...

# ──────────────────────────────────────────────
# Development
# ──────────────────────────────────────────────

# Vite dev server port (default: 5173, set in vite.config.ts)
# VITE_PORT=5173
