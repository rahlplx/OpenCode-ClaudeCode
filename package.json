    "react-dom": "^19.1.0",
    "react-router-dom": "^7.12.0",
    "ws": "^8.18.3",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.5.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "tailwindcss": "^4.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.0"
