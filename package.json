{
  "name": "opencode-claudecode",
  "version": "0.1.0",
  "description": "AI coding agent using OpenCode backend with Kanna web UI",
  "main": "electron/main.cjs",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "opencode-cc": "./dist-cli/index.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:cli": "tsup",
    "build:electron": "pnpm build && pnpm build:cli",
    "build:win": "pnpm build:electron && electron-builder --win --x64",
    "build:mac": "pnpm build:electron && electron-builder --mac",
    "build:linux": "pnpm build:electron && electron-builder --linux",
    "electron:dev": "pnpm build:electron && electron electron/main.cjs",
    "cap:sync": "cap sync android",
    "build:android": "pnpm build && cap sync android",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@legendapp/list": "3.0.0-beta.44",
    "@opencode-ai/sdk": "^1.17.8",
    "@pierre/diffs": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-select": "^2.2.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "commander": "^13.1.0",
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-resizable-panels": "^4.7.3",
    "react-router-dom": "^7.12.0",
    "ws": "^8.18.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.10"
  },
  "build": {
    "appId": "com.opencode.claudecode",
    "productName": "OpenCode",
    "copyright": "Copyright © 2026 OpenCode-ClaudeCode Contributors",
    "asar": false,
    "directories": { "output": "dist-electron" },
    "files": ["electron/**/*", "dist-cli/**/*", "dist/**/*", "package.json"],
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] },
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "public/icon-512.png",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenCode"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "public/icon-512.png",
      "category": "public.app-category.developer-tools"
    },
    "dmg": { "title": "OpenCode ${version}" },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "public/icon-512.png",
      "category": "Development"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "electron"
    ]
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "lucide-react": "^0.562.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.1.0",
    "vitest": "^3.0.0"
  }
}
